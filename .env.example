# CLUTCH bot — шаблон переменных окружения.
# Скопируй в .env и впиши свои значения. .env в git НЕ попадает (см. .gitignore).

# ── Telegram-бот (обязательно) ──
BOT_TOKEN=             # токен от @BotFather
ADMIN_ID=              # твой Telegram ID (узнать: /myid в боте)

# ── Каналы ──
CHANNEL_ID=@clutch_anketi          # канал автопостинга анкет (или пусто)
NEWS_CHANNEL_ID=                   # числовой ID канала новостей (-100...)
NEWS_CHANNEL_URL=https://t.me/clutch_news_gg

# ── Юзербот (премиум-эмодзи + большие видео). api с my.telegram.org ──
TG_API_ID=
TG_API_HASH=
TG_SESSION=            # создаётся скриптом: python3 userbot_login.py (QR + 2FA)

# ── PandaScore (живые матчи CS2/Dota2). Бесплатно: pandascore.co ──
PANDASCORE_TOKEN=

# ── AI-комментатор. Ключ: aistudio.google.com/app/apikey ──
GEMINI_API_KEY=
# ANTHROPIC_API_KEY=   # альтернатива Gemini (Claude)

# ── Deepgram (авто-субтитры по словам). Бесплатно: deepgram.com ──
DEEPGRAM_API_KEY=

# ── Instagram автопостинг (Graph API). Настройка: см. README ──
FB_APP_ID=
FB_APP_SECRET=
IG_USER_ID=            # ID Instagram Business аккаунта
IG_PAGE_ID=            # ID связанной Facebook-страницы
IG_PAGE_TOKEN=         # постоянный page access token (expires_at=0)

# ── Необязательные настройки ──
# NEWS_DAILY=5         # постов новостей в день
# IG_FEED_DAILY=3      # постов в IG-ленту в день
